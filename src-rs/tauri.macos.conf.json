{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Isekai",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 19
        }
      },
      {
        "label": "overlay",
        "title": "Isekai Overlay",
        "width": 360,
        "height": 420,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ]
  }
}
